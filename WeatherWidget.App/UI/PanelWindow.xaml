<Window x:Class="WeatherWidget.App.UI.PanelWindow"
        x:Name="RootWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:WeatherWidget.App.Models"
        xmlns:conv="clr-namespace:WeatherWidget.App.UI.Converters"
        xmlns:ctrl="clr-namespace:WeatherWidget.App.UI.Controls"
        Title="天气面板"
        Width="1620"
        Height="540"
        WindowStartupLocation="Manual"
        ShowInTaskbar="False"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        UseLayoutRounding="True">
    <Window.Resources>
        <conv:WeatherCodeToChipIconConverter x:Key="WeatherIconConverter" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- 左侧设置面板 -->
        <Border Grid.Column="1"
                Background="{DynamicResource CardBackgroundBrush}"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="18"
                Padding="16"
                Margin="0,0,8,0"
                Visibility="{Binding IsSettingsPanelVisible, Converter={StaticResource BoolToVis}}"
                SnapsToDevicePixels="True">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Width="540">
                <StackPanel>
                    <TextBlock Text="设置" Style="{StaticResource SectionTitleText}" />

                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- 左列：基础、图标、样式 -->
                        <StackPanel Grid.Row="0" Grid.Column="0" Grid.RowSpan="3">
                            <!-- 基础设置 -->
                            <Border Background="{DynamicResource SoftPanelBrush}" CornerRadius="12" Padding="12">
                                <StackPanel>
                                    <TextBlock Text="基础设置" Style="{StaticResource ValueText}" FontWeight="SemiBold" />
                                    <Grid Margin="0,8,0,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="城市" Style="{StaticResource SubtleText}" VerticalAlignment="Center" />
                                        <ComboBox Grid.Row="0" Grid.Column="1" IsEditable="True" IsTextSearchEnabled="False"
                                                  Text="{Binding City, UpdateSourceTrigger=PropertyChanged}"
                                                  ItemsSource="{Binding CitySuggestions}" SelectedItem="{Binding SelectedCitySuggestion}"
                                                  DisplayMemberPath="DisplayName" Margin="6,0,0,0" />
                                        <Button Grid.Row="0" Grid.Column="2" Content="保存" Command="{Binding SaveSettingsCommand}" Style="{StaticResource TinyButton}" Margin="6,0,0,0" />
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="频率" Style="{StaticResource SubtleText}" VerticalAlignment="Center" Margin="0,8,0,0" />
                                        <ComboBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" SelectedValue="{Binding RefreshMinutes}" SelectedValuePath="Tag" Margin="6,8,0,0">
                                            <ComboBoxItem Content="5分钟" Tag="5" />
                                            <ComboBoxItem Content="10分钟" Tag="10" />
                                            <ComboBoxItem Content="30分钟" Tag="30" />
                                            <ComboBoxItem Content="1小时" Tag="60" />
                                        </ComboBox>
                                    </Grid>
                                    <CheckBox Content="开机启动" IsChecked="{Binding AutoStart}" Margin="0,8,0,0" />
                                    <CheckBox Content="启动时默认隐藏" IsChecked="{Binding StartHidden}" Margin="0,8,0,0" IsEnabled="{Binding AutoStart}" />
                                </StackPanel>
                            </Border>

                            <!-- 图标设置 -->
                            <Border Background="{DynamicResource SoftPanelBrush}" CornerRadius="12" Padding="12" Margin="0,10,0,0">
                                <StackPanel>
                                    <TextBlock Text="图标设置" Style="{StaticResource ValueText}" FontWeight="SemiBold" />
                                    <CheckBox Content="显示圆角背景" IsChecked="{Binding IconBackgroundEnabled}" Margin="0,8,0,0" />
                                    <Grid Margin="0,6,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="24" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="偏移X" Style="{StaticResource SubtleText}" VerticalAlignment="Center" />
                                        <Slider Grid.Column="1" Minimum="-12" Maximum="12" TickFrequency="1" IsSnapToTickEnabled="True"
                                                Value="{Binding IconOffsetX, UpdateSourceTrigger=PropertyChanged}" Margin="6,0,0,0" />
                                        <TextBlock Grid.Column="2" Text="{Binding IconOffsetX, StringFormat=0}" Style="{StaticResource SubtleText}" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                    </Grid>
                                    <Grid Margin="0,6,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="24" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="偏移Y" Style="{StaticResource SubtleText}" VerticalAlignment="Center" />
                                        <Slider Grid.Column="1" Minimum="-12" Maximum="12" TickFrequency="1" IsSnapToTickEnabled="True"
                                                Value="{Binding IconOffsetY, UpdateSourceTrigger=PropertyChanged}" Margin="6,0,0,0" />
                                        <TextBlock Grid.Column="2" Text="{Binding IconOffsetY, StringFormat=0}" Style="{StaticResource SubtleText}" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- 嵌入任务栏设置 -->
                            <Border Background="{DynamicResource SoftPanelBrush}" CornerRadius="12" Padding="12" Margin="0,10,0,0">
                                <StackPanel>
                                    <TextBlock Text="嵌入任务栏设置" Style="{StaticResource ValueText}" FontWeight="SemiBold" />
                                    <TextBlock Text="提示：嵌入模式文字复用下方角标配置（字号=FontScale，颜色=Color，间隔=OffsetX）" Style="{StaticResource SubtleText}" TextWrapping="Wrap" Margin="0,6,0,0" />
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="文字布局" Style="{StaticResource SubtleText}" VerticalAlignment="Center" />
                                        <ComboBox Grid.Column="1" SelectedValue="{Binding EmbeddedTextLayout}" SelectedValuePath="Tag" Margin="6,0,0,0">
                                            <ComboBoxItem Content="两行" Tag="{x:Static models:EmbeddedTextLayout.TwoLines}" />
                                        </ComboBox>
                                    </Grid>
                                    <Grid Margin="0,6,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="对齐" Style="{StaticResource SubtleText}" VerticalAlignment="Center" />
                                        <ComboBox Grid.Column="1" SelectedValue="{Binding EmbeddedTextAlignment}" SelectedValuePath="Tag" Margin="6,0,0,0">
                                            <ComboBoxItem Content="左对齐" Tag="{x:Static models:EmbeddedTextAlignment.Left}" />
                                            <ComboBoxItem Content="居中" Tag="{x:Static models:EmbeddedTextAlignment.Center}" />
                                            <ComboBoxItem Content="右对齐" Tag="{x:Static models:EmbeddedTextAlignment.Right}" />
                                        </ComboBox>
                                    </Grid>
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="48" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="图标大小" Style="{StaticResource SubtleText}" VerticalAlignment="Center" />
                                        <Slider Grid.Column="1" Minimum="0.5" Maximum="1.6" TickFrequency="0.1" IsSnapToTickEnabled="True"
                                                Value="{Binding EmbeddedIconScale, UpdateSourceTrigger=PropertyChanged}" Margin="6,0,0,0" />
                                        <TextBlock Grid.Column="2" Text="{Binding EmbeddedIconScale, StringFormat=x{0:0.0}}" Style="{StaticResource SubtleText}" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                    </Grid>
                                    <Grid Margin="0,6,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="48" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="左右偏移" Style="{StaticResource SubtleText}" VerticalAlignment="Center" />
                                        <Slider Grid.Column="1" Minimum="-300" Maximum="300" TickFrequency="10" IsSnapToTickEnabled="True"
                                                Value="{Binding EmbeddedOffsetX, UpdateSourceTrigger=PropertyChanged}" Margin="6,0,0,0" />
                                        <TextBlock Grid.Column="2" Text="{Binding EmbeddedOffsetX, StringFormat=0}" Style="{StaticResource SubtleText}" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                    </Grid>
                                    <Grid Margin="0,6,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="48" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="UV-天气间距" Style="{StaticResource SubtleText}" VerticalAlignment="Center" />
                                        <Slider Grid.Column="1" Minimum="2" Maximum="40" TickFrequency="1" IsSnapToTickEnabled="True"
                                                Value="{Binding EmbeddedUvToWeatherGap, UpdateSourceTrigger=PropertyChanged}" Margin="6,0,0,0" />
                                        <TextBlock Grid.Column="2" Text="{Binding EmbeddedUvToWeatherGap, StringFormat=0}" Style="{StaticResource SubtleText}" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                    </Grid>
                                    <Grid Margin="0,6,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="72" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="悬停延迟" Style="{StaticResource SubtleText}" VerticalAlignment="Center" />
                                        <Slider Grid.Column="1" Minimum="0" Maximum="2000" TickFrequency="50" IsSnapToTickEnabled="True"
                                                Value="{Binding EmbeddedHoverDelayMs, UpdateSourceTrigger=PropertyChanged}" Margin="6,0,0,0" />
                                        <TextBlock Grid.Column="2" Text="{Binding EmbeddedHoverDelayMs, StringFormat={}{0}ms}" Style="{StaticResource SubtleText}" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- 样式设置 -->
                            <Border Background="{DynamicResource SoftPanelBrush}" CornerRadius="12" Padding="12" Margin="0,10,0,0">
                                <StackPanel>
                                    <TextBlock Text="样式设置" Style="{StaticResource ValueText}" FontWeight="SemiBold" />
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="字体" Style="{StaticResource SubtleText}" VerticalAlignment="Center" />
                                        <ComboBox Grid.Column="1" ItemsSource="{Binding SystemFontFamilies}" SelectedItem="{Binding BadgeFontFamily}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding}" FontFamily="{Binding}" />
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </Grid>
                                    <CheckBox Content="显示背景（关闭则描边）" IsChecked="{Binding BadgeBackgroundEnabled}" Margin="0,8,0,0" />
                                    <Grid Margin="0,6,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="40" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="描边" Style="{StaticResource SubtleText}" VerticalAlignment="Center" />
                                        <Slider Grid.Column="1" Minimum="0.5" Maximum="6.0" TickFrequency="0.5" IsSnapToTickEnabled="True"
                                                Value="{Binding BadgeStrokeWidth, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Grid.Column="2" Text="{Binding BadgeStrokeWidth, StringFormat={}{0:0.0}}" Style="{StaticResource SubtleText}" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                    </Grid>
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="主题" Style="{StaticResource SubtleText}" VerticalAlignment="Center" />
                                        <ComboBox Grid.Column="1" SelectedValue="{Binding ThemeMode}" SelectedValuePath="Tag">
                                            <ComboBoxItem Content="跟随日出日落" Tag="{x:Static models:ThemeMode.Auto}" />
                                            <ComboBoxItem Content="浅色" Tag="{x:Static models:ThemeMode.Light}" />
                                            <ComboBoxItem Content="深色" Tag="{x:Static models:ThemeMode.Dark}" />
                                            <ComboBoxItem Content="海洋" Tag="{x:Static models:ThemeMode.Ocean}" />
                                            <ComboBoxItem Content="森林" Tag="{x:Static models:ThemeMode.Forest}" />
                                            <ComboBoxItem Content="日落" Tag="{x:Static models:ThemeMode.Sunset}" />
                                            <ComboBoxItem Content="薰衣草" Tag="{x:Static models:ThemeMode.Lavender}" />
                                            <ComboBoxItem Content="玫瑰" Tag="{x:Static models:ThemeMode.Rose}" />
                                            <ComboBoxItem Content="薄荷" Tag="{x:Static models:ThemeMode.Mint}" />
                                            <ComboBoxItem Content="摩卡" Tag="{x:Static models:ThemeMode.Mocha}" />
                                            <ComboBoxItem Content="石板" Tag="{x:Static models:ThemeMode.Slate}" />
                                            <ComboBoxItem Content="樱桃" Tag="{x:Static models:ThemeMode.Cherry}" />
                                            <ComboBoxItem Content="琥珀" Tag="{x:Static models:ThemeMode.Amber}" />
                                            <ComboBoxItem Content="黑曜石" Tag="{x:Static models:ThemeMode.Obsidian}" />
                                            <ComboBoxItem Content="炭黑" Tag="{x:Static models:ThemeMode.Charcoal}" />
                                            <ComboBoxItem Content="午夜" Tag="{x:Static models:ThemeMode.Midnight}" />
                                            <ComboBoxItem Content="雪白" Tag="{x:Static models:ThemeMode.Snow}" />
                                            <ComboBoxItem Content="象牙" Tag="{x:Static models:ThemeMode.Ivory}" />
                                            <ComboBoxItem Content="珍珠" Tag="{x:Static models:ThemeMode.Pearl}" />
                                        </ComboBox>
                                    </Grid>
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="60" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="图标模式" Style="{StaticResource SubtleText}" VerticalAlignment="Center" />
                                        <ComboBox Grid.Column="1" SelectedValue="{Binding IconDisplayMode}" SelectedValuePath="Tag">
                                            <ComboBoxItem Content="合并（单图标）" Tag="{x:Static models:IconDisplayMode.Combined}" />
                                            <ComboBoxItem Content="分离（双图标）" Tag="{x:Static models:IconDisplayMode.Separate}" />
                                            <ComboBoxItem Content="嵌入任务栏" Tag="{x:Static models:IconDisplayMode.Embedded}" />
                                        </ComboBox>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- 右列：温度、副角标、额外 -->
                        <StackPanel Grid.Row="0" Grid.Column="2" Grid.RowSpan="3">
                            <!-- 温度角标 -->
                            <Border Background="{DynamicResource SoftPanelBrush}" CornerRadius="12" Padding="12">
                                <StackPanel>
                                    <TextBlock Text="温度角标" Style="{StaticResource ValueText}" FontWeight="SemiBold" />
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="位置" Style="{StaticResource SubtleText}" VerticalAlignment="Center" />
                                        <ComboBox Grid.Column="1" SelectedValue="{Binding TempBadgePosition}" SelectedValuePath="Tag">
                                            <ComboBoxItem Content="左上" Tag="{x:Static models:BadgePosition.TopLeft}" />
                                            <ComboBoxItem Content="上方" Tag="{x:Static models:BadgePosition.Top}" />
                                            <ComboBoxItem Content="右上" Tag="{x:Static models:BadgePosition.TopRight}" />
                                            <ComboBoxItem Content="左侧" Tag="{x:Static models:BadgePosition.Left}" />
                                            <ComboBoxItem Content="右侧" Tag="{x:Static models:BadgePosition.Right}" />
                                            <ComboBoxItem Content="左下" Tag="{x:Static models:BadgePosition.BottomLeft}" />
                                            <ComboBoxItem Content="下方" Tag="{x:Static models:BadgePosition.Bottom}" />
                                            <ComboBoxItem Content="右下" Tag="{x:Static models:BadgePosition.BottomRight}" />
                                        </ComboBox>
                                    </Grid>
                                    <Grid Margin="0,6,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="格式" Style="{StaticResource SubtleText}" VerticalAlignment="Center" />
                                        <TextBox Grid.Column="1" Text="{Binding TempBadgeFormat, UpdateSourceTrigger=PropertyChanged}" />
                                    </Grid>
                                    <Grid Margin="0,6,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="颜色" Style="{StaticResource SubtleText}" VerticalAlignment="Center" />
                                        <ctrl:ColorPicker Grid.Column="1" SelectedColor="{Binding TempBadgeColor, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Left" />
                                    </Grid>
                                    <Grid Margin="0,6,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="32" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="偏移" Style="{StaticResource SubtleText}" VerticalAlignment="Center" />
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <TextBlock Text="X" Style="{StaticResource SubtleText}" VerticalAlignment="Center" />
                                            <Slider Width="60" Minimum="-18" Maximum="18" TickFrequency="1" IsSnapToTickEnabled="True"
                                                    Value="{Binding TempBadgeOffsetX, UpdateSourceTrigger=PropertyChanged}" Margin="4,0,8,0" />
                                            <TextBlock Text="Y" Style="{StaticResource SubtleText}" VerticalAlignment="Center" />
                                            <Slider Width="60" Minimum="-18" Maximum="18" TickFrequency="1" IsSnapToTickEnabled="True"
                                                    Value="{Binding TempBadgeOffsetY, UpdateSourceTrigger=PropertyChanged}" Margin="4,0,0,0" />
                                        </StackPanel>
                                    </Grid>
                                    <Grid Margin="0,6,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="40" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="字号" Style="{StaticResource SubtleText}" VerticalAlignment="Center" />
                                        <Slider Grid.Column="1" Minimum="0.7" Maximum="2.0" TickFrequency="0.1" IsSnapToTickEnabled="True"
                                                Value="{Binding TempBadgeFontScale, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Grid.Column="2" Text="{Binding TempBadgeFontScale, StringFormat=x{0:0.0}}" Style="{StaticResource SubtleText}" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- 副角标 -->
                            <Border Background="{DynamicResource SoftPanelBrush}" CornerRadius="12" Padding="12" Margin="0,10,0,0">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="副角标" Style="{StaticResource ValueText}" FontWeight="SemiBold" />
                                        <ComboBox SelectedValue="{Binding IconCornerMetric}" SelectedValuePath="Tag" Margin="8,0,0,0">
                                            <ComboBoxItem Content="关闭" Tag="{x:Static models:IconCornerMetric.Off}" />
                                            <ComboBoxItem Content="UV" Tag="{x:Static models:IconCornerMetric.UvIndex}" />
                                            <ComboBoxItem Content="湿度" Tag="{x:Static models:IconCornerMetric.Humidity}" />
                                        </ComboBox>
                                    </StackPanel>
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="位置" Style="{StaticResource SubtleText}" VerticalAlignment="Center" />
                                        <ComboBox Grid.Column="1" SelectedValue="{Binding CornerBadgePosition}" SelectedValuePath="Tag">
                                            <ComboBoxItem Content="左上" Tag="{x:Static models:BadgePosition.TopLeft}" />
                                            <ComboBoxItem Content="上方" Tag="{x:Static models:BadgePosition.Top}" />
                                            <ComboBoxItem Content="右上" Tag="{x:Static models:BadgePosition.TopRight}" />
                                            <ComboBoxItem Content="左侧" Tag="{x:Static models:BadgePosition.Left}" />
                                            <ComboBoxItem Content="右侧" Tag="{x:Static models:BadgePosition.Right}" />
                                            <ComboBoxItem Content="左下" Tag="{x:Static models:BadgePosition.BottomLeft}" />
                                            <ComboBoxItem Content="下方" Tag="{x:Static models:BadgePosition.Bottom}" />
                                            <ComboBoxItem Content="右下" Tag="{x:Static models:BadgePosition.BottomRight}" />
                                        </ComboBox>
                                    </Grid>
                                    <Grid Margin="0,6,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="颜色" Style="{StaticResource SubtleText}" VerticalAlignment="Center" />
                                        <ctrl:ColorPicker Grid.Column="1" SelectedColor="{Binding CornerBadgeColor, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Left" />
                                    </Grid>
                                    <Grid Margin="0,6,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="32" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="偏移" Style="{StaticResource SubtleText}" VerticalAlignment="Center" />
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <TextBlock Text="X" Style="{StaticResource SubtleText}" VerticalAlignment="Center" />
                                            <Slider Width="60" Minimum="-18" Maximum="18" TickFrequency="1" IsSnapToTickEnabled="True"
                                                    Value="{Binding CornerBadgeOffsetX, UpdateSourceTrigger=PropertyChanged}" Margin="4,0,8,0" />
                                            <TextBlock Text="Y" Style="{StaticResource SubtleText}" VerticalAlignment="Center" />
                                            <Slider Width="60" Minimum="-18" Maximum="18" TickFrequency="1" IsSnapToTickEnabled="True"
                                                    Value="{Binding CornerBadgeOffsetY, UpdateSourceTrigger=PropertyChanged}" Margin="4,0,0,0" />
                                        </StackPanel>
                                    </Grid>
                                    <Grid Margin="0,6,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="40" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="字号" Style="{StaticResource SubtleText}" VerticalAlignment="Center" />
                                        <Slider Grid.Column="1" Minimum="0.7" Maximum="2.0" TickFrequency="0.1" IsSnapToTickEnabled="True"
                                                Value="{Binding CornerBadgeFontScale, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Grid.Column="2" Text="{Binding CornerBadgeFontScale, StringFormat=x{0:0.0}}" Style="{StaticResource SubtleText}" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- 额外角标 -->
                            <Border Background="{DynamicResource SoftPanelBrush}" CornerRadius="12" Padding="12" Margin="0,10,0,0">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="额外角标" Style="{StaticResource ValueText}" FontWeight="SemiBold" />
                                        <CheckBox Content="启用" IsChecked="{Binding ExtraBadgeEnabled}" Margin="12,0,0,0" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="位置" Style="{StaticResource SubtleText}" VerticalAlignment="Center" />
                                        <ComboBox Grid.Column="1" SelectedValue="{Binding ExtraBadgePosition}" SelectedValuePath="Tag">
                                            <ComboBoxItem Content="左上" Tag="{x:Static models:BadgePosition.TopLeft}" />
                                            <ComboBoxItem Content="上方" Tag="{x:Static models:BadgePosition.Top}" />
                                            <ComboBoxItem Content="右上" Tag="{x:Static models:BadgePosition.TopRight}" />
                                            <ComboBoxItem Content="左侧" Tag="{x:Static models:BadgePosition.Left}" />
                                            <ComboBoxItem Content="右侧" Tag="{x:Static models:BadgePosition.Right}" />
                                            <ComboBoxItem Content="左下" Tag="{x:Static models:BadgePosition.BottomLeft}" />
                                            <ComboBoxItem Content="下方" Tag="{x:Static models:BadgePosition.Bottom}" />
                                            <ComboBoxItem Content="右下" Tag="{x:Static models:BadgePosition.BottomRight}" />
                                        </ComboBox>
                                    </Grid>
                                    <Grid Margin="0,6,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="格式" Style="{StaticResource SubtleText}" VerticalAlignment="Center" />
                                        <TextBox Grid.Column="1" Text="{Binding ExtraBadgeFormat, UpdateSourceTrigger=PropertyChanged}" />
                                    </Grid>
                                    <Grid Margin="0,6,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="颜色" Style="{StaticResource SubtleText}" VerticalAlignment="Center" />
                                        <ctrl:ColorPicker Grid.Column="1" SelectedColor="{Binding ExtraBadgeColor, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Left" />
                                    </Grid>
                                    <Grid Margin="0,6,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="32" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="偏移" Style="{StaticResource SubtleText}" VerticalAlignment="Center" />
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <TextBlock Text="X" Style="{StaticResource SubtleText}" VerticalAlignment="Center" />
                                            <Slider Width="60" Minimum="-18" Maximum="18" TickFrequency="1" IsSnapToTickEnabled="True"
                                                    Value="{Binding ExtraBadgeOffsetX, UpdateSourceTrigger=PropertyChanged}" Margin="4,0,8,0" />
                                            <TextBlock Text="Y" Style="{StaticResource SubtleText}" VerticalAlignment="Center" />
                                            <Slider Width="60" Minimum="-18" Maximum="18" TickFrequency="1" IsSnapToTickEnabled="True"
                                                    Value="{Binding ExtraBadgeOffsetY, UpdateSourceTrigger=PropertyChanged}" Margin="4,0,0,0" />
                                        </StackPanel>
                                    </Grid>
                                    <Grid Margin="0,6,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="40" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="字号" Style="{StaticResource SubtleText}" VerticalAlignment="Center" />
                                        <Slider Grid.Column="1" Minimum="0.7" Maximum="2.0" TickFrequency="0.1" IsSnapToTickEnabled="True"
                                                Value="{Binding ExtraBadgeFontScale, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Grid.Column="2" Text="{Binding ExtraBadgeFontScale, StringFormat=x{0:0.0}}" Style="{StaticResource SubtleText}" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                    </Grid>
                                    <TextBlock Text="支持: {temp} {uv} {rh}" Style="{StaticResource SubtleText}" Margin="0,6,0,0" FontSize="10" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- 主面板 -->
        <Border Grid.Column="3"
                Width="800"
                Background="{DynamicResource CardBackgroundBrush}"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="18"
                Padding="16"
                VerticalAlignment="Bottom"
                SnapsToDevicePixels="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding LocationText}" Style="{StaticResource TitleText}" VerticalAlignment="Center" />
                        <Button Content="刷新" Command="{Binding RefreshCommand}" Style="{StaticResource TinyButton}"
                                Margin="8,0,0,0" VerticalAlignment="Center" ToolTip="刷新天气" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                        <Button Content="退出" Command="{Binding ExitCommand}" Style="{StaticResource TinyButton}" />
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1" Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                         <Border Padding="14" Background="{DynamicResource SoftPanelBrush}" CornerRadius="16">
                             <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="{Binding CurrentTempText}" Style="{StaticResource BigNumberText}" />
                                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                        <TextBlock Text="湿度 " Style="{StaticResource SubtleText}" />
                                        <TextBlock Text="{Binding CurrentHumidityText}" Style="{StaticResource ValueText}" Margin="0,0,12,0" />
                                        <TextBlock Text="UV " Style="{StaticResource SubtleText}" />
                                        <TextBlock Text="{Binding CurrentUvText}" Style="{StaticResource ValueText}" />
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Top">
                                    <TextBlock Text="最近更新" Style="{StaticResource SubtleText}" HorizontalAlignment="Right" />
                                    <TextBlock Text="{Binding LastUpdatedText}" Style="{StaticResource ValueText}" HorizontalAlignment="Right" Margin="0,4,0,0" />
                                    <TextBlock Text="{Binding StatusText}" Style="{StaticResource SubtleText}" HorizontalAlignment="Right" Margin="0,8,0,0" TextAlignment="Right" />
                                </StackPanel>
                             </Grid>
                         </Border>

                         <!-- 简化的更新信息 (点击展开日志) -->
                         <Button Command="{Binding ToggleLogPanelCommand}" Margin="0,10,0,0" Cursor="Hand">
                             <Button.Template>
                                 <ControlTemplate TargetType="Button">
                                     <Border x:Name="Bd" Background="{DynamicResource SoftPanelBrush}" CornerRadius="12" Padding="10">
                                         <Grid>
                                             <Grid.ColumnDefinitions>
                                                 <ColumnDefinition Width="*" />
                                                 <ColumnDefinition Width="Auto" />
                                             </Grid.ColumnDefinitions>
                                             <TextBlock Text="{Binding UpdateLogHeaderLine}" Style="{StaticResource SubtleText}" TextWrapping="Wrap" VerticalAlignment="Center" />
                                             <TextBlock Grid.Column="1" Text="📋" FontSize="14" Foreground="{DynamicResource InkBrush}" VerticalAlignment="Center" Margin="6,0,0,0" Opacity="0.6" ToolTip="点击查看日志" />
                                         </Grid>
                                     </Border>
                                     <ControlTemplate.Triggers>
                                         <Trigger Property="IsMouseOver" Value="True">
                                             <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverBackgroundBrush}" />
                                         </Trigger>
                                     </ControlTemplate.Triggers>
                                 </ControlTemplate>
                             </Button.Template>
                         </Button>

                         <!-- 设置按钮 -->
                         <Button Content="⚙️ 设置" Command="{Binding ToggleSettingsPanelCommand}"
                                 Style="{StaticResource TinyButton}" Margin="0,10,0,0" HorizontalAlignment="Left" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="14,0,0,0">
                         <TextBlock Text="未来 5 天" Style="{StaticResource SectionTitleText}" />
                         <ItemsControl ItemsSource="{Binding ForecastDays}" Margin="0,10,0,0">
                             <ItemsControl.ItemsPanel>
                                 <ItemsPanelTemplate>
                                     <UniformGrid Columns="5" />
                                 </ItemsPanelTemplate>
                             </ItemsControl.ItemsPanel>
                             <ItemsControl.ItemTemplate>
                                 <DataTemplate>
                                     <Button Style="{StaticResource CardButton}"
                                            Margin="0,0,10,0"
                                            Padding="10,12"
                                            Command="{Binding DataContext.ToggleDayDetailCommand, ElementName=RootWindow}"
                                            CommandParameter="{Binding}">
                                         <Grid>
                                             <Grid.RowDefinitions>
                                                 <RowDefinition Height="Auto" />
                                                 <RowDefinition Height="Auto" />
                                                 <RowDefinition Height="Auto" />
                                                 <RowDefinition Height="Auto" />
                                             </Grid.RowDefinitions>

                                            <StackPanel Grid.Row="0" HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding DayLabel}" Style="{StaticResource ValueText}" HorizontalAlignment="Center" />
                                                <TextBlock Text="{Binding WeatherText}" Style="{StaticResource SubtleText}" HorizontalAlignment="Center" FontSize="10" Margin="0,2,0,0" />
                                            </StackPanel>

                                            <Border Grid.Row="1" Width="40" Height="40" CornerRadius="12" Background="{DynamicResource IconChipBrush}"
                                                    HorizontalAlignment="Center" Margin="0,10,0,0">
                                                <Image Source="{Binding WeatherCode, Converter={StaticResource WeatherIconConverter}}"
                                                       Stretch="Uniform"
                                                       Margin="4" />
                                            </Border>

                                            <TextBlock Grid.Row="2" Text="{Binding TempRange}" Style="{StaticResource SubtleText}"
                                                       HorizontalAlignment="Center" Margin="0,10,0,0" />

                                            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                                                <TextBlock Text="UV " Style="{StaticResource SubtleText}" FontSize="11" />
                                                <TextBlock Text="{Binding UvMax}" Style="{StaticResource ValueText}" FontSize="11" Margin="0,0,8,0" />
                                                <TextBlock Text="雨 " Style="{StaticResource SubtleText}" FontSize="11" />
                                                <TextBlock Text="{Binding PrecipitationProbability}" Style="{StaticResource ValueText}" FontSize="11" />
                                            </StackPanel>
                                         </Grid>
                                     </Button>
                                 </DataTemplate>
                             </ItemsControl.ItemTemplate>
                         </ItemsControl>

                         <Border Background="{DynamicResource SoftPanelBrush}"
                                 CornerRadius="16"
                                 Padding="12"
                                 Margin="0,12,0,0"
                                 Visibility="{Binding IsDayDetailVisible, Converter={StaticResource BoolToVis}}">
                             <StackPanel>
                                 <TextBlock Text="{Binding SelectedDayDetailTitle}" Style="{StaticResource SectionTitleText}" />

                                 <!-- 图例 -->
                                 <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                     <Border Width="12" Height="3" Background="#FFFF8C00" CornerRadius="1" VerticalAlignment="Center" />
                                     <TextBlock Text=" 温度" Style="{StaticResource SubtleText}" Margin="0,0,12,0" />
                                     <Border Width="12" Height="3" Background="#FF4382FF" CornerRadius="1" VerticalAlignment="Center" />
                                     <TextBlock Text=" 湿度" Style="{StaticResource SubtleText}" Margin="0,0,12,0" />
                                     <Border Width="2" Height="12" Background="#FFFF5252" CornerRadius="1" VerticalAlignment="Center" />
                                     <TextBlock Text=" 当前时间" Style="{StaticResource SubtleText}" />
                                 </StackPanel>

                                 <Viewbox Stretch="Fill" Height="160" Margin="0,10,0,0">
                                     <Canvas Width="200" Height="62">
                                         <!-- 温度曲线（橙色） -->
                                         <Path Data="{Binding TemperatureChartGeometry}"
                                               Stroke="#FFFF8C00"
                                               StrokeThickness="1.0"
                                               StrokeLineJoin="Round"
                                               StrokeStartLineCap="Round"
                                               StrokeEndLineCap="Round"
                                               Canvas.Top="10" />

                                         <!-- 湿度曲线（蓝色） -->
                                         <Path Data="{Binding HumidityChartGeometry}"
                                               Stroke="#FF4382FF"
                                               StrokeThickness="1.0"
                                               StrokeLineJoin="Round"
                                               StrokeStartLineCap="Round"
                                               StrokeEndLineCap="Round"
                                               Canvas.Top="10" />

                                         <!-- 当前时间线 -->
                                         <Line X1="{Binding CurrentTimeLineX}" Y1="0"
                                               X2="{Binding CurrentTimeLineX}" Y2="62"
                                               Stroke="#FFFF5252"
                                               StrokeThickness="0.6"
                                               StrokeDashArray="2,1"
                                               Visibility="{Binding ShowCurrentTimeLine, Converter={StaticResource BoolToVis}}" />

                                         <!-- 最高最低点标记 -->
                                         <ItemsControl ItemsSource="{Binding ChartMarkers}" Canvas.Top="10">
                                             <ItemsControl.ItemsPanel>
                                                 <ItemsPanelTemplate>
                                                     <Canvas Width="200" Height="62" />
                                                 </ItemsPanelTemplate>
                                             </ItemsControl.ItemsPanel>
                                             <ItemsControl.ItemContainerStyle>
                                                 <Style TargetType="ContentPresenter">
                                                     <Setter Property="Canvas.Left" Value="{Binding X}" />
                                                     <Setter Property="Canvas.Top" Value="{Binding Y}" />
                                                 </Style>
                                             </ItemsControl.ItemContainerStyle>
                                             <ItemsControl.ItemTemplate>
                                                 <DataTemplate>
                                                     <TextBlock Text="{Binding Label}"
                                                                Foreground="{Binding Color}"
                                                                FontSize="3.8"
                                                                FontWeight="SemiBold">
                                                         <TextBlock.RenderTransform>
                                                             <!-- 水平居中并上调一个字号高度 -->
                                                             <TranslateTransform X="-2.5" Y="-4.0" />
                                                         </TextBlock.RenderTransform>
                                                     </TextBlock>
                                                 </DataTemplate>
                                             </ItemsControl.ItemTemplate>
                                         </ItemsControl>
                                     </Canvas>
                                 </Viewbox>

                                 <!-- 24小时天气图标行 -->
                                 <ItemsControl ItemsSource="{Binding TemperatureHourIcons}" Margin="0,8,0,0">
                                     <ItemsControl.ItemsPanel>
                                         <ItemsPanelTemplate>
                                             <UniformGrid Columns="8" />
                                         </ItemsPanelTemplate>
                                     </ItemsControl.ItemsPanel>
                                     <ItemsControl.ItemTemplate>
                                         <DataTemplate>
                                             <Border Padding="2" CornerRadius="6" Margin="1">
                                                 <Border.Style>
                                                     <Style TargetType="Border">
                                                         <Style.Triggers>
                                                             <DataTrigger Binding="{Binding IsCurrentHour}" Value="True">
                                                                 <Setter Property="Background" Value="#33FF5252" />
                                                             </DataTrigger>
                                                         </Style.Triggers>
                                                     </Style>
                                                 </Border.Style>
                                                 <StackPanel HorizontalAlignment="Center">
                                                     <TextBlock Text="{Binding TimeLabel}"
                                                                FontSize="10"
                                                                HorizontalAlignment="Center">
                                                         <TextBlock.Style>
                                                             <Style TargetType="TextBlock" BasedOn="{StaticResource SubtleText}">
                                                                 <Setter Property="FontSize" Value="10" />
                                                                 <Style.Triggers>
                                                                     <DataTrigger Binding="{Binding IsCurrentHour}" Value="True">
                                                                         <Setter Property="Foreground" Value="#FFFF5252" />
                                                                         <Setter Property="FontWeight" Value="Bold" />
                                                                     </DataTrigger>
                                                                 </Style.Triggers>
                                                             </Style>
                                                         </TextBlock.Style>
                                                     </TextBlock>
                                                     <Border Width="26" Height="26" CornerRadius="8" Background="{DynamicResource IconChipBrush}"
                                                             HorizontalAlignment="Center" Margin="0,3,0,0">
                                                         <Image Source="{Binding WeatherCode, Converter={StaticResource WeatherIconConverter}}"
                                                                Stretch="Uniform"
                                                                Margin="3" />
                                                     </Border>
                                                     <TextBlock Text="{Binding TempLabel}"
                                                                Style="{StaticResource ValueText}"
                                                                FontSize="11"
                                                                HorizontalAlignment="Center"
                                                                Margin="0,2,0,0" />
                                                 </StackPanel>
                                             </Border>
                                         </DataTemplate>
                                     </ItemsControl.ItemTemplate>
                                 </ItemsControl>

                                 <StackPanel Margin="0,8,0,0">
                                     <TextBlock Text="{Binding SelectedDayTempSummary}" Foreground="#FFFF8C00" Style="{StaticResource SubtleText}" />
                                     <TextBlock Text="{Binding SelectedDayHumiditySummary}" Foreground="#FF4382FF" Style="{StaticResource SubtleText}" Margin="0,2,0,0" />
                                 </StackPanel>
                             </StackPanel>
                         </Border>
                     </StackPanel>
                 </Grid>
             </Grid>
         </Border>

        <!-- 日志面板（主面板左侧） -->
        <Border Grid.Column="2"
                Background="{DynamicResource CardBackgroundBrush}"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="18"
                Padding="16"
                Margin="0,0,8,0"
                Visibility="{Binding IsLogPanelVisible, Converter={StaticResource BoolToVis}}"
                SnapsToDevicePixels="True">
            <StackPanel Width="268">
                <TextBlock Text="更新日志" Style="{StaticResource SectionTitleText}" />
                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="460" Margin="0,12,0,0">
                    <ItemsControl ItemsSource="{Binding UpdateLogs}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" Style="{StaticResource SubtleText}" TextWrapping="Wrap" Margin="0,0,0,4" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </StackPanel>
        </Border>
    </Grid>
</Window>
