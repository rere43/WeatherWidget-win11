<Window x:Class="WeatherWidget.App.UI.PanelWindow"
        x:Name="RootWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:WeatherWidget.App.Models"
        xmlns:conv="clr-namespace:WeatherWidget.App.UI.Converters"
        xmlns:ctrl="clr-namespace:WeatherWidget.App.UI.Controls"
        Title="天气面板"
        Width="1620"
        Height="540"
        WindowStartupLocation="Manual"
        ShowInTaskbar="False"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        UseLayoutRounding="True">
    <Window.Resources>
        <conv:WeatherCodeToChipIconConverter x:Key="WeatherIconConverter" />
        <conv:ScaleCoordinateConverter x:Key="ScaleCoord" />
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- 左侧设置面板 -->
        <Border Grid.Column="1"
                Background="{DynamicResource CardBackgroundBrush}"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="18"
                Padding="16"
                Margin="0,0,8,0"
                Visibility="{Binding IsSettingsPanelVisible, Converter={StaticResource BoolToVis}}"
                SnapsToDevicePixels="True">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Width="540">
                <StackPanel>
                    <TextBlock Text="设置" Style="{StaticResource SectionTitleText}" />

                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- 左列：基础、图标、样式 -->
                        <StackPanel Grid.Row="0" Grid.Column="0" Grid.RowSpan="3" Grid.ColumnSpan="3">
                            <!-- 基础设置 -->
                            <Border Background="{DynamicResource SoftPanelBrush}" CornerRadius="12" Padding="12">
                                <StackPanel>
                                    <TextBlock Text="基础设置" Style="{StaticResource ValueText}" FontWeight="SemiBold" />
                                    <Grid Margin="0,8,0,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="城市" Style="{StaticResource SubtleText}" VerticalAlignment="Center" />
                                        <Grid Grid.Row="0" Grid.Column="1" Margin="6,0,0,0">
                                            <TextBox x:Name="CityTextBox"
                                                     Text="{Binding City, UpdateSourceTrigger=PropertyChanged}"
                                                     GotFocus="CityTextBox_GotFocus"
                                                     LostFocus="CityTextBox_LostFocus" />
                                            <Popup x:Name="CitySuggestionPopup"
                                                   PlacementTarget="{Binding ElementName=CityTextBox}"
                                                   Placement="Bottom"
                                                   IsOpen="{Binding IsCityDropdownOpen, Mode=TwoWay}"
                                                   StaysOpen="True"
                                                   AllowsTransparency="True"
                                                   PopupAnimation="Fade">
                                                <Border Background="{DynamicResource CardBackgroundBrush}"
                                                        BorderBrush="{DynamicResource CardBorderBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="6"
                                                        Padding="4"
                                                        MinWidth="{Binding ActualWidth, ElementName=CityTextBox}"
                                                        MaxHeight="280">
                                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                        <StackPanel>
                                                            <!-- 查询中提示 -->
                                                            <TextBlock Text="{Binding CitySearchStatusText}"
                                                                       Style="{StaticResource SubtleText}"
                                                                       Margin="8,6"
                                                                       Visibility="{Binding IsCitySearching, Converter={StaticResource BoolToVis}}" />

                                                            <!-- 自定义地点列表 (总是显示，有特殊标识) -->
                                                            <ItemsControl x:Name="CustomLocationsControl" ItemsSource="{Binding CustomLocations}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Border Background="Transparent"
                                                                                Padding="8,6"
                                                                                Cursor="Hand"
                                                                                MouseLeftButtonDown="CustomLocationItem_Click">
                                                                            <Border.Style>
                                                                                <Style TargetType="Border">
                                                                                    <Style.Triggers>
                                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                                            <Setter Property="Background" Value="{DynamicResource HoverBackgroundBrush}" />
                                                                                        </Trigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </Border.Style>
                                                                            <StackPanel Orientation="Horizontal">
                                                                                <Border Background="{DynamicResource AccentBrush}"
                                                                                        CornerRadius="3"
                                                                                        Padding="4,1"
                                                                                        Margin="0,0,6,0"
                                                                                        VerticalAlignment="Center">
                                                                                    <TextBlock Text="★"
                                                                                               FontSize="9"
                                                                                               Foreground="{DynamicResource CardBackgroundBrush}" />
                                                                                </Border>
                                                                                <TextBlock Text="{Binding Name}"
                                                                                           Foreground="{DynamicResource InkBrush}"
                                                                                           VerticalAlignment="Center" />
                                                                            </StackPanel>
                                                                        </Border>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>

                                                            <!-- 分隔线 (有自定义地点时显示) -->
                                                            <Border Height="1"
                                                                    Background="{DynamicResource CardBorderBrush}"
                                                                    Margin="8,4"
                                                                    Visibility="{Binding HasItems, ElementName=CustomLocationsControl, Converter={StaticResource BoolToVis}}" />

                                                            <!-- 搜索结果列表 -->
                                                            <ItemsControl ItemsSource="{Binding CitySuggestions}"
                                                                          Visibility="{Binding IsCitySearching, Converter={StaticResource InverseBoolToVis}}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Border Background="Transparent"
                                                                                Padding="8,6"
                                                                                Cursor="Hand"
                                                                                MouseLeftButtonDown="CitySuggestionBorder_Click">
                                                                            <Border.Style>
                                                                                <Style TargetType="Border">
                                                                                    <Style.Triggers>
                                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                                            <Setter Property="Background" Value="{DynamicResource HoverBackgroundBrush}" />
                                                                                        </Trigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </Border.Style>
                                                                            <TextBlock Text="{Binding DisplayName}"
                                                                                       Foreground="{DynamicResource InkBrush}" />
                                                                        </Border>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </StackPanel>
                                                    </ScrollViewer>
                                                </Border>
                                            </Popup>
                                        </Grid>
                                        <Button Grid.Row="0" Grid.Column="2" Content="保存" Command="{Binding SaveSettingsCommand}" Style="{StaticResource TinyButton}" Margin="6,0,0,0" />

                                        <!-- 自定义地点设置 -->
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="地名" Style="{StaticResource SubtleText}" VerticalAlignment="Center" Margin="0,8,0,0" />
                                        <Grid Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Margin="6,8,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0"
                                                     Text="{Binding CustomLocationName, UpdateSourceTrigger=PropertyChanged}"
                                                     ToolTip="自定义地点名称"
                                                     Foreground="{DynamicResource InkBrush}" />
                                            <Button Grid.Column="1" Content="添加"
                                                    Command="{Binding AddCustomLocationCommand}"
                                                    Style="{StaticResource TinyButton}"
                                                    Margin="6,0,0,0"
                                                    ToolTip="添加当前坐标为自定义地点" />
                                        </Grid>

                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="坐标" Style="{StaticResource SubtleText}" VerticalAlignment="Center" Margin="0,8,0,0" />
                                        <Grid Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Margin="6,8,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="8" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0"
                                                     Text="{Binding DisplayLatitude, StringFormat=F4, UpdateSourceTrigger=PropertyChanged}"
                                                     ToolTip="纬度"
                                                     Foreground="{DynamicResource InkBrush}" />
                                            <TextBox Grid.Column="2"
                                                     Text="{Binding DisplayLongitude, StringFormat=F4, UpdateSourceTrigger=PropertyChanged}"
                                                     ToolTip="经度"
                                                     Foreground="{DynamicResource InkBrush}" />
                                        </Grid>

                                        <!-- 已保存的自定义地点 -->
                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="已存" Style="{StaticResource SubtleText}" VerticalAlignment="Top" Margin="0,8,0,0" />
                                        <ItemsControl Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2"
                                                      ItemsSource="{Binding CustomLocations}"
                                                      Margin="6,8,0,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="{DynamicResource SoftPanelBrush}"
                                                            CornerRadius="4"
                                                            Padding="6,3"
                                                            Margin="0,0,0,4">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0"
                                                                       Foreground="{DynamicResource InkBrush}"
                                                                       VerticalAlignment="Center">
                                                                <Run Text="{Binding Name, Mode=OneWay}" />
                                                                <Run Text=" (" Foreground="{DynamicResource SubtleInkBrush}" FontSize="10" />
                                                                <Run Text="{Binding Latitude, Mode=OneWay, StringFormat=F2}" Foreground="{DynamicResource SubtleInkBrush}" FontSize="10" />
                                                                <Run Text=", " Foreground="{DynamicResource SubtleInkBrush}" FontSize="10" />
                                                                <Run Text="{Binding Longitude, Mode=OneWay, StringFormat=F2}" Foreground="{DynamicResource SubtleInkBrush}" FontSize="10" />
                                                                <Run Text=")" Foreground="{DynamicResource SubtleInkBrush}" FontSize="10" />
                                                            </TextBlock>
                                                            <Button Grid.Column="1"
                                                                    Content="×"
                                                                    Command="{Binding DataContext.RemoveCustomLocationCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                    CommandParameter="{Binding}"
                                                                    Style="{StaticResource TinyButton}"
                                                                    FontSize="12"
                                                                    Padding="4,0"
                                                                    ToolTip="删除" />
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <TextBlock Grid.Row="4" Grid.Column="0" Text="频率" Style="{StaticResource SubtleText}" VerticalAlignment="Center" Margin="0,8,0,0" />
                                        <ComboBox Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2" SelectedValue="{Binding RefreshMinutes}" SelectedValuePath="Tag" Margin="6,8,0,0">
                                            <ComboBoxItem Content="5分钟" Tag="5" />
                                            <ComboBoxItem Content="10分钟" Tag="10" />
                                            <ComboBoxItem Content="30分钟" Tag="30" />
                                            <ComboBoxItem Content="1小时" Tag="60" />
                                        </ComboBox>
                                    </Grid>
                                    <CheckBox Content="开机启动" IsChecked="{Binding AutoStart}" Margin="0,8,0,0" />
                                    <CheckBox Content="启动时默认隐藏" IsChecked="{Binding StartHidden}" Margin="0,8,0,0" IsEnabled="{Binding AutoStart}" />
                                </StackPanel>
                            </Border>

                            <!-- 天气图标 -->
                            <Border Background="{DynamicResource SoftPanelBrush}" CornerRadius="12" Padding="12" Margin="0,10,0,0">
                                <StackPanel>
                                    <TextBlock Text="天气图标" Style="{StaticResource ValueText}" FontWeight="SemiBold" />
                                    <CheckBox Content="显示圆角背景" IsChecked="{Binding EmbeddedWeatherIconBackgroundEnabled}" Margin="0,8,0,0" />
                                    <Grid Margin="0,6,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="24" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="偏移X" Style="{StaticResource SubtleText}" VerticalAlignment="Center" />
                                        <Slider Grid.Column="1" Minimum="-12" Maximum="12" TickFrequency="1" IsSnapToTickEnabled="True"
                                                Value="{Binding EmbeddedWeatherIconOffsetX, UpdateSourceTrigger=PropertyChanged}" Margin="6,0,0,0" />
                                        <TextBlock Grid.Column="2" Text="{Binding EmbeddedWeatherIconOffsetX, StringFormat=0}" Style="{StaticResource SubtleText}" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                    </Grid>
                                    <Grid Margin="0,6,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="24" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="偏移Y" Style="{StaticResource SubtleText}" VerticalAlignment="Center" />
                                        <Slider Grid.Column="1" Minimum="-12" Maximum="12" TickFrequency="1" IsSnapToTickEnabled="True"
                                                Value="{Binding EmbeddedWeatherIconOffsetY, UpdateSourceTrigger=PropertyChanged}" Margin="6,0,0,0" />
                                        <TextBlock Grid.Column="2" Text="{Binding EmbeddedWeatherIconOffsetY, StringFormat=0}" Style="{StaticResource SubtleText}" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- 嵌入任务栏设置 -->
                            <Border Background="{DynamicResource SoftPanelBrush}" CornerRadius="12" Padding="12" Margin="0,10,0,0">
                                <StackPanel>
                                    <TextBlock Text="嵌入任务栏设置" Style="{StaticResource ValueText}" FontWeight="SemiBold" />
                                    <TextBlock Text="用于任务栏嵌入组件的布局与交互参数。" Style="{StaticResource SubtleText}" TextWrapping="Wrap" Margin="0,6,0,0" />
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="48" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="图标大小" Style="{StaticResource SubtleText}" VerticalAlignment="Center" />
                                        <Slider Grid.Column="1" Minimum="0.5" Maximum="1.6" TickFrequency="0.1" IsSnapToTickEnabled="True"
                                                Value="{Binding EmbeddedIconScale, UpdateSourceTrigger=PropertyChanged}" Margin="6,0,0,0" />
                                        <TextBlock Grid.Column="2" Text="{Binding EmbeddedIconScale, StringFormat=x{0:0.0}}" Style="{StaticResource SubtleText}" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                    </Grid>
                                    <Grid Margin="0,6,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="48" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="左右偏移" Style="{StaticResource SubtleText}" VerticalAlignment="Center" />
                                        <Slider Grid.Column="1" Minimum="-300" Maximum="300" TickFrequency="10" IsSnapToTickEnabled="True"
                                                Value="{Binding EmbeddedOffsetX, UpdateSourceTrigger=PropertyChanged}" Margin="6,0,0,0" />
                                        <TextBlock Grid.Column="2" Text="{Binding EmbeddedOffsetX, StringFormat=0}" Style="{StaticResource SubtleText}" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                    </Grid>
                                    <Grid Margin="0,6,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="48" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="UV-图标间距" Style="{StaticResource SubtleText}" VerticalAlignment="Center" />
                                        <Slider Grid.Column="1" Minimum="2" Maximum="40" TickFrequency="1" IsSnapToTickEnabled="True"
                                                Value="{Binding EmbeddedUvToIconGap, UpdateSourceTrigger=PropertyChanged}" Margin="6,0,0,0" />
                                        <TextBlock Grid.Column="2" Text="{Binding EmbeddedUvToIconGap, StringFormat=0}" Style="{StaticResource SubtleText}" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                    </Grid>
                                    <Grid Margin="0,6,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="48" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="图标-文字间距" Style="{StaticResource SubtleText}" VerticalAlignment="Center" />
                                        <Slider Grid.Column="1" Minimum="2" Maximum="40" TickFrequency="1" IsSnapToTickEnabled="True"
                                                Value="{Binding EmbeddedIconToTextGap, UpdateSourceTrigger=PropertyChanged}" Margin="6,0,0,0" />
                                        <TextBlock Grid.Column="2" Text="{Binding EmbeddedIconToTextGap, StringFormat=0}" Style="{StaticResource SubtleText}" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                    </Grid>
                                    <Grid Margin="0,6,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="48" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="行间距" Style="{StaticResource SubtleText}" VerticalAlignment="Center" />
                                        <Slider Grid.Column="1" Minimum="0" Maximum="40" TickFrequency="1" IsSnapToTickEnabled="True"
                                                Value="{Binding EmbeddedLineSpacing, UpdateSourceTrigger=PropertyChanged}" Margin="6,0,0,0" />
                                        <TextBlock Grid.Column="2" Text="{Binding EmbeddedLineSpacing, StringFormat=0}" Style="{StaticResource SubtleText}" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                    </Grid>
                                    <Grid Margin="0,6,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="48" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="UV数字字号" Style="{StaticResource SubtleText}" VerticalAlignment="Center" />
                                        <Slider Grid.Column="1" Minimum="0.5" Maximum="6.0" TickFrequency="0.1" IsSnapToTickEnabled="True"
                                                Value="{Binding EmbeddedUvNumberFontScale, UpdateSourceTrigger=PropertyChanged}" Margin="6,0,0,0" />
                                        <TextBlock Grid.Column="2" Text="{Binding EmbeddedUvNumberFontScale, StringFormat=x{0:0.0}}" Style="{StaticResource SubtleText}" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                    </Grid>
                                    <Grid Margin="0,6,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="72" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="悬停延迟" Style="{StaticResource SubtleText}" VerticalAlignment="Center" />
                                        <Slider Grid.Column="1" Minimum="0" Maximum="2000" TickFrequency="50" IsSnapToTickEnabled="True"
                                                Value="{Binding EmbeddedHoverDelayMs, UpdateSourceTrigger=PropertyChanged}" Margin="6,0,0,0" />
                                        <TextBlock Grid.Column="2" Text="{Binding EmbeddedHoverDelayMs, StringFormat={}{0}ms}" Style="{StaticResource SubtleText}" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                    </Grid>
                                    <Grid Margin="0,6,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="72" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="悬停固定时间" Style="{StaticResource SubtleText}" VerticalAlignment="Center" />
                                        <Slider Grid.Column="1" Minimum="0" Maximum="2000" TickFrequency="50" IsSnapToTickEnabled="True"
                                                Value="{Binding EmbeddedHoverPinMs, UpdateSourceTrigger=PropertyChanged}" Margin="6,0,0,0" />
                                        <TextBlock Grid.Column="2" Text="{Binding EmbeddedHoverPinMs, StringFormat={}{0}ms}" Style="{StaticResource SubtleText}" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- 样式设置 -->
                            <Border Background="{DynamicResource SoftPanelBrush}" CornerRadius="12" Padding="12" Margin="0,10,0,0">
                                <StackPanel>
                                    <TextBlock Text="样式设置" Style="{StaticResource ValueText}" FontWeight="SemiBold" />
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="字体" Style="{StaticResource SubtleText}" VerticalAlignment="Center" />
                                        <ComboBox Grid.Column="1" ItemsSource="{Binding SystemFontFamilies}" SelectedItem="{Binding EmbeddedFontFamily}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding}" FontFamily="{Binding}" />
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </Grid>
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="40" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="温度字号" Style="{StaticResource SubtleText}" VerticalAlignment="Center" />
                                        <Slider Grid.Column="1" Minimum="0.5" Maximum="3.0" TickFrequency="0.1" IsSnapToTickEnabled="True"
                                                Value="{Binding EmbeddedTemperatureFontScale, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Grid.Column="2" Text="{Binding EmbeddedTemperatureFontScale, StringFormat=x{0:0.0}}" Style="{StaticResource SubtleText}" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                    </Grid>
                                    <Grid Margin="0,6,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="40" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="湿度字号" Style="{StaticResource SubtleText}" VerticalAlignment="Center" />
                                        <Slider Grid.Column="1" Minimum="0.5" Maximum="3.0" TickFrequency="0.1" IsSnapToTickEnabled="True"
                                                Value="{Binding EmbeddedHumidityFontScale, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Grid.Column="2" Text="{Binding EmbeddedHumidityFontScale, StringFormat=x{0:0.0}}" Style="{StaticResource SubtleText}" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                    </Grid>
                                    <Grid Margin="0,6,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="40" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="描边" Style="{StaticResource SubtleText}" VerticalAlignment="Center" />
                                        <Slider Grid.Column="1" Minimum="0" Maximum="8.0" TickFrequency="0.5" IsSnapToTickEnabled="True"
                                                Value="{Binding EmbeddedTextStrokeWidth, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Grid.Column="2" Text="{Binding EmbeddedTextStrokeWidth, StringFormat={}{0:0.0}}" Style="{StaticResource SubtleText}" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                    </Grid>
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="温度格式" Style="{StaticResource SubtleText}" VerticalAlignment="Center" />
                                        <TextBox Grid.Column="1" Text="{Binding EmbeddedTemperatureFormat, UpdateSourceTrigger=PropertyChanged}" />
                                    </Grid>
                                    <Grid Margin="0,6,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="湿度格式" Style="{StaticResource SubtleText}" VerticalAlignment="Center" />
                                        <TextBox Grid.Column="1" Text="{Binding EmbeddedHumidityFormat, UpdateSourceTrigger=PropertyChanged}" />
                                    </Grid>
                                    <Grid Margin="0,6,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="UV格式" Style="{StaticResource SubtleText}" VerticalAlignment="Center" />
                                        <TextBox Grid.Column="1" Text="{Binding EmbeddedUvNumberFormat, UpdateSourceTrigger=PropertyChanged}" />
                                    </Grid>
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="温度色" Style="{StaticResource SubtleText}" VerticalAlignment="Center" />
                                        <ctrl:ColorPicker Grid.Column="1" SelectedColor="{Binding EmbeddedTemperatureColor, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Left" />
                                    </Grid>
                                    <Grid Margin="0,6,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="湿度色" Style="{StaticResource SubtleText}" VerticalAlignment="Center" />
                                        <ctrl:ColorPicker Grid.Column="1" SelectedColor="{Binding EmbeddedHumidityColor, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Left" />
                                    </Grid>
                                    <Grid Margin="0,6,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="UV数字色" Style="{StaticResource SubtleText}" VerticalAlignment="Center" />
                                        <ctrl:ColorPicker Grid.Column="1" SelectedColor="{Binding EmbeddedUvNumberColor, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Left" />
                                    </Grid>
                                    <Grid Margin="0,6,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="UV填充色" Style="{StaticResource SubtleText}" VerticalAlignment="Center" />
                                        <ctrl:ColorPicker Grid.Column="1" SelectedColor="{Binding EmbeddedUvBarFillColor, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Left" />
                                    </Grid>
                                    <Grid Margin="0,6,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="UV底色" Style="{StaticResource SubtleText}" VerticalAlignment="Center" />
                                        <ctrl:ColorPicker Grid.Column="1" SelectedColor="{Binding EmbeddedUvBarBackgroundColor, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Left" />
                                    </Grid>
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="主题" Style="{StaticResource SubtleText}" VerticalAlignment="Center" />
                                        <ComboBox Grid.Column="1" SelectedValue="{Binding ThemeMode}" SelectedValuePath="Tag">
                                            <ComboBoxItem Content="跟随日出日落" Tag="{x:Static models:ThemeMode.Auto}" />
                                            <ComboBoxItem Content="浅色" Tag="{x:Static models:ThemeMode.Light}" />
                                            <ComboBoxItem Content="深色" Tag="{x:Static models:ThemeMode.Dark}" />
                                            <ComboBoxItem Content="海洋" Tag="{x:Static models:ThemeMode.Ocean}" />
                                            <ComboBoxItem Content="森林" Tag="{x:Static models:ThemeMode.Forest}" />
                                            <ComboBoxItem Content="日落" Tag="{x:Static models:ThemeMode.Sunset}" />
                                            <ComboBoxItem Content="薰衣草" Tag="{x:Static models:ThemeMode.Lavender}" />
                                            <ComboBoxItem Content="玫瑰" Tag="{x:Static models:ThemeMode.Rose}" />
                                            <ComboBoxItem Content="薄荷" Tag="{x:Static models:ThemeMode.Mint}" />
                                            <ComboBoxItem Content="摩卡" Tag="{x:Static models:ThemeMode.Mocha}" />
                                            <ComboBoxItem Content="石板" Tag="{x:Static models:ThemeMode.Slate}" />
                                            <ComboBoxItem Content="樱桃" Tag="{x:Static models:ThemeMode.Cherry}" />
                                            <ComboBoxItem Content="琥珀" Tag="{x:Static models:ThemeMode.Amber}" />
                                            <ComboBoxItem Content="黑曜石" Tag="{x:Static models:ThemeMode.Obsidian}" />
                                            <ComboBoxItem Content="炭黑" Tag="{x:Static models:ThemeMode.Charcoal}" />
                                            <ComboBoxItem Content="午夜" Tag="{x:Static models:ThemeMode.Midnight}" />
                                            <ComboBoxItem Content="雪白" Tag="{x:Static models:ThemeMode.Snow}" />
                                            <ComboBoxItem Content="象牙" Tag="{x:Static models:ThemeMode.Ivory}" />
                                            <ComboBoxItem Content="珍珠" Tag="{x:Static models:ThemeMode.Pearl}" />
                                        </ComboBox>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- 主面板 -->
        <Border Grid.Column="3"
                Width="800"
                Background="{DynamicResource CardBackgroundBrush}"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="18"
                Padding="16"
                VerticalAlignment="Bottom"
                SnapsToDevicePixels="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding LocationText}" Style="{StaticResource TitleText}" VerticalAlignment="Center" />
                        <Button Content="刷新" Command="{Binding RefreshCommand}" Style="{StaticResource TinyButton}"
                                Margin="8,0,0,0" VerticalAlignment="Center" ToolTip="刷新天气" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                        <Button Content="退出" Command="{Binding ExitCommand}" Style="{StaticResource TinyButton}" />
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1" Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0">
                         <Border Padding="14" Background="{DynamicResource SoftPanelBrush}" CornerRadius="16">
                             <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="{Binding CurrentTempText}" Style="{StaticResource BigNumberText}" />
                                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                        <TextBlock Text="湿度 " Style="{StaticResource SubtleText}" />
                                        <TextBlock Text="{Binding CurrentHumidityText}" Style="{StaticResource ValueText}" Margin="0,0,12,0" />
                                        <TextBlock Text="UV " Style="{StaticResource SubtleText}" />
                                        <TextBlock Text="{Binding CurrentUvText}" Style="{StaticResource ValueText}" />
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Top">
                                    <TextBlock Text="最近更新" Style="{StaticResource SubtleText}" HorizontalAlignment="Right" />
                                    <TextBlock Text="{Binding LastUpdatedText}" Style="{StaticResource ValueText}" HorizontalAlignment="Right" Margin="0,4,0,0" />
                                    <TextBlock Text="{Binding StatusText}" Style="{StaticResource SubtleText}" HorizontalAlignment="Right" Margin="0,8,0,0" TextAlignment="Right" />
                                </StackPanel>
                             </Grid>
                         </Border>

                         <!-- 简化的更新信息 (点击展开日志) -->
                         <Button Command="{Binding ToggleLogPanelCommand}" Margin="0,10,0,0" Cursor="Hand">
                             <Button.Template>
                                 <ControlTemplate TargetType="Button">
                                     <Border x:Name="Bd" Background="{DynamicResource SoftPanelBrush}" CornerRadius="12" Padding="10">
                                         <Grid>
                                             <Grid.ColumnDefinitions>
                                                 <ColumnDefinition Width="*" />
                                                 <ColumnDefinition Width="Auto" />
                                             </Grid.ColumnDefinitions>
                                             <TextBlock Text="{Binding UpdateLogHeaderLine}" Style="{StaticResource SubtleText}" TextWrapping="Wrap" VerticalAlignment="Center" />
                                             <TextBlock Grid.Column="1" Text="📋" FontSize="14" Foreground="{DynamicResource InkBrush}" VerticalAlignment="Center" Margin="6,0,0,0" Opacity="0.6" ToolTip="点击查看日志" />
                                         </Grid>
                                     </Border>
                                     <ControlTemplate.Triggers>
                                         <Trigger Property="IsMouseOver" Value="True">
                                             <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverBackgroundBrush}" />
                                         </Trigger>
                                     </ControlTemplate.Triggers>
                                 </ControlTemplate>
                             </Button.Template>
                         </Button>

                         <!-- 设置按钮 -->
                         <Button Content="⚙️ 设置" Command="{Binding ToggleSettingsPanelCommand}"
                                 Style="{StaticResource TinyButton}" Margin="0,10,0,0" HorizontalAlignment="Left" />
                    </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="14,0,0,0">
                         <StackPanel Orientation="Horizontal">
                             <TextBlock Text="未来 5 天" Style="{StaticResource SectionTitleText}" />
                             <TextBlock Text="{Binding TemperatureTrend}" Style="{StaticResource SubtleText}" VerticalAlignment="Center" Margin="6,0,0,0" />
                         </StackPanel>
                         <ItemsControl ItemsSource="{Binding ForecastDays}" Margin="0,10,0,0">
                             <ItemsControl.ItemsPanel>
                                 <ItemsPanelTemplate>
                                     <UniformGrid Columns="5" />
                                 </ItemsPanelTemplate>
                             </ItemsControl.ItemsPanel>
                             <ItemsControl.ItemTemplate>
                                 <DataTemplate>
                                     <Button Style="{StaticResource CardButton}"
                                            Margin="0,0,10,0"
                                            Padding="10,12"
                                            Command="{Binding DataContext.ToggleDayDetailCommand, ElementName=RootWindow}"
                                            CommandParameter="{Binding}">
                                         <Grid>
                                             <Grid.RowDefinitions>
                                                 <RowDefinition Height="Auto" />
                                                 <RowDefinition Height="Auto" />
                                                 <RowDefinition Height="Auto" />
                                                 <RowDefinition Height="Auto" />
                                             </Grid.RowDefinitions>

                                            <StackPanel Grid.Row="0" HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding DayLabel}" Style="{StaticResource ValueText}" HorizontalAlignment="Center" />
                                                <TextBlock Text="{Binding WeatherText}" Style="{StaticResource SubtleText}" HorizontalAlignment="Center" FontSize="10" Margin="0,2,0,0" />
                                            </StackPanel>

                                            <Border Grid.Row="1" Width="40" Height="40" CornerRadius="12" Background="{DynamicResource IconChipBrush}"
                                                    HorizontalAlignment="Center" Margin="0,10,0,0">
                                                <Image Source="{Binding WeatherCode, Converter={StaticResource WeatherIconConverter}}"
                                                       Stretch="Uniform"
                                                       Margin="4" />
                                            </Border>

                                            <TextBlock Grid.Row="2" Text="{Binding TempRange}" Style="{StaticResource SubtleText}"
                                                       HorizontalAlignment="Center" Margin="0,10,0,0" />

                                            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                                                <TextBlock Text="UV " Style="{StaticResource SubtleText}" FontSize="11" />
                                                <TextBlock Text="{Binding UvMax}" Style="{StaticResource ValueText}" FontSize="11" Margin="0,0,8,0" />
                                                <TextBlock Text="雨 " Style="{StaticResource SubtleText}" FontSize="11" />
                                                <TextBlock Text="{Binding PrecipitationProbability}" Style="{StaticResource ValueText}" FontSize="11" />
                                            </StackPanel>
                                         </Grid>
                                     </Button>
                                 </DataTemplate>
                             </ItemsControl.ItemTemplate>
                          </ItemsControl>
                     </StackPanel>

                    <Border Grid.Row="1"
                            Grid.Column="0"
                            Grid.ColumnSpan="2"
                            Background="{DynamicResource SoftPanelBrush}"
                            CornerRadius="16"
                            Padding="12"
                            Margin="0,12,0,0"
                            Visibility="{Binding IsDayDetailVisible, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <TextBlock Text="{Binding SelectedDayDetailTitle}" Style="{StaticResource SectionTitleText}" />

                            <!-- 图例 -->
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <Border Width="12" Height="3" Background="#FFFF8C00" CornerRadius="1" VerticalAlignment="Center" />
                                <TextBlock Text=" 温度" Style="{StaticResource SubtleText}" Margin="0,0,12,0" />
                                <Border Width="12" Height="3" Background="#FF4382FF" CornerRadius="1" VerticalAlignment="Center" />
                                <TextBlock Text=" 湿度" Style="{StaticResource SubtleText}" Margin="0,0,12,0" />
                                <Border Width="2" Height="12" Background="#FFFF5252" CornerRadius="1" VerticalAlignment="Center" />
                                <TextBlock Text=" 当前时间" Style="{StaticResource SubtleText}" />
                            </StackPanel>

                            <Grid Height="160" Margin="0,10,0,0">
                                <Viewbox Stretch="Fill">
                                    <Canvas Width="200" Height="62">
                                        <!-- 温度曲线（橙色） -->
                                        <Path Data="{Binding TemperatureChartGeometry}"
                                              Stroke="#FFFF8C00"
                                              StrokeThickness="1.0"
                                              StrokeLineJoin="Round"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              Canvas.Top="10" />

                                        <!-- 湿度曲线（蓝色） -->
                                        <Path Data="{Binding HumidityChartGeometry}"
                                              Stroke="#FF4382FF"
                                              StrokeThickness="1.0"
                                              StrokeLineJoin="Round"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              Canvas.Top="10" />

                                        <!-- 当前时间线 -->
                                        <Line X1="{Binding CurrentTimeLineX}" Y1="5"
                                              X2="{Binding CurrentTimeLineX}" Y2="62"
                                              Stroke="#FFFF5252"
                                              StrokeThickness="0.6"
                                              StrokeDashArray="2,1"
                                              Visibility="{Binding ShowCurrentTimeLine, Converter={StaticResource BoolToVis}}" />

                                    </Canvas>
                                </Viewbox>

                                <!-- 最高最低点标记：单独绘制，避免随 Viewbox 横向拉伸导致数字变形 -->
                                <Canvas x:Name="DayDetailChartOverlay" IsHitTestVisible="False">
                                    <!-- 当前时刻数值 -->
                                    <TextBlock Visibility="{Binding ShowCurrentTimeLine, Converter={StaticResource BoolToVis}}"
                                               FontSize="10"
                                               FontWeight="SemiBold">
                                        <TextBlock.RenderTransform>
                                            <TranslateTransform X="-22" Y="-13" />
                                        </TextBlock.RenderTransform>
                                        <Canvas.Left>
                                            <MultiBinding Converter="{StaticResource ScaleCoord}" ConverterParameter="200">
                                                <Binding Path="CurrentTimeLineX" />
                                                <Binding ElementName="DayDetailChartOverlay" Path="ActualWidth" />
                                            </MultiBinding>
                                        </Canvas.Left>
                                        <Canvas.Top>
                                            <MultiBinding Converter="{StaticResource ScaleCoord}" ConverterParameter="62">
                                                <Binding Path="CurrentTimeMarkerY" />
                                                <Binding ElementName="DayDetailChartOverlay" Path="ActualHeight" />
                                            </MultiBinding>
                                        </Canvas.Top>
                                        <Run Text="{Binding CurrentTimeTempText, Mode=OneWay}" Foreground="#FFFF8C00" />
                                        <Run Text=" " />
                                        <Run Text="{Binding CurrentTimeHumidityText, Mode=OneWay}" Foreground="#FF4382FF" />
                                    </TextBlock>
                                    <ItemsControl ItemsSource="{Binding ChartMarkers}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <Canvas />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemContainerStyle>
                                            <Style TargetType="ContentPresenter">
                                                <Setter Property="Canvas.Left">
                                                    <Setter.Value>
                                                        <MultiBinding Converter="{StaticResource ScaleCoord}" ConverterParameter="200">
                                                            <Binding Path="X" />
                                                            <Binding ElementName="DayDetailChartOverlay" Path="ActualWidth" />
                                                        </MultiBinding>
                                                    </Setter.Value>
                                                </Setter>
                                                <Setter Property="Canvas.Top">
                                                    <Setter.Value>
                                                        <MultiBinding Converter="{StaticResource ScaleCoord}" ConverterParameter="62,10">
                                                            <Binding Path="Y" />
                                                            <Binding ElementName="DayDetailChartOverlay" Path="ActualHeight" />
                                                        </MultiBinding>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ItemsControl.ItemContainerStyle>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Label}"
                                                           Foreground="{Binding Color}"
                                                           FontSize="10"
                                                           FontWeight="SemiBold">
                                                    <TextBlock.RenderTransform>
                                                        <TranslateTransform X="-10" Y="-10" />
                                                    </TextBlock.RenderTransform>
                                                </TextBlock>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Canvas>
                            </Grid>

                            <!-- 24小时天气图标行 -->
                            <ItemsControl ItemsSource="{Binding TemperatureHourIcons}" Margin="0,8,0,0">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="{Binding TemperatureHourIcons.Count}" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="2" CornerRadius="6" Margin="1">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsCurrentHour}" Value="True">
                                                            <Setter Property="Background" Value="#33FF5252" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding TimeLabel}"
                                                           FontSize="10"
                                                           HorizontalAlignment="Center"
                                                           TextWrapping="NoWrap">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock" BasedOn="{StaticResource SubtleText}">
                                                            <Setter Property="FontSize" Value="10" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsCurrentHour}" Value="True">
                                                                    <Setter Property="Foreground" Value="#FFFF5252" />
                                                                    <Setter Property="FontWeight" Value="Bold" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <Border Width="26" Height="26" CornerRadius="8" Background="{DynamicResource IconChipBrush}"
                                                        HorizontalAlignment="Center" Margin="0,3,0,0">
                                                    <Image Source="{Binding WeatherCode, Converter={StaticResource WeatherIconConverter}}"
                                                           Stretch="Uniform"
                                                           Margin="3" />
                                                </Border>
                                                <TextBlock Text="{Binding TempLabel}"
                                                           Style="{StaticResource ValueText}"
                                                           FontSize="11"
                                                           HorizontalAlignment="Center"
                                                           Margin="0,2,0,0"
                                                           TextWrapping="NoWrap" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <StackPanel Margin="0,8,0,0">
                                <TextBlock Text="{Binding SelectedDayTempSummary}" Foreground="#FFFF8C00" Style="{StaticResource SubtleText}" />
                                <TextBlock Text="{Binding SelectedDayHumiditySummary}" Foreground="#FF4382FF" Style="{StaticResource SubtleText}" Margin="0,2,0,0" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

                <ProgressBar Grid.Row="2"
                             Height="6"
                             Margin="0,12,0,0"
                             Minimum="0"
                             Maximum="100"
                             Value="{Binding HoverPinProgressPercent}"
                             Foreground="#FFDA70D6"
                             Background="{DynamicResource SoftPanelBrush}"
                             Visibility="{Binding IsHoverPinProgressVisible, Converter={StaticResource BoolToVis}}" />
            </Grid>
        </Border>

        <!-- 日志面板（主面板左侧） -->
        <Border Grid.Column="2"
                Background="{DynamicResource CardBackgroundBrush}"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="18"
                Padding="16"
                Margin="0,0,8,0"
                Visibility="{Binding IsLogPanelVisible, Converter={StaticResource BoolToVis}}"
                SnapsToDevicePixels="True">
            <StackPanel Width="268">
                <TextBlock Text="更新日志" Style="{StaticResource SectionTitleText}" />
                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="460" Margin="0,12,0,0">
                    <ItemsControl ItemsSource="{Binding UpdateLogs}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" Style="{StaticResource SubtleText}" TextWrapping="Wrap" Margin="0,0,0,4" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </StackPanel>
        </Border>
    </Grid>
</Window>
