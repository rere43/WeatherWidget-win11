<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- 摩卡主题 (深色) - 咖啡棕色系，沉稳大气 -->
    <Color x:Key="InkColor">#FFF5EDE6</Color>
    <Color x:Key="SubtleInkColor">#FFB8A89A</Color>
    <Color x:Key="CardBgColor">#FF2C221A</Color>
    <Color x:Key="CardBorderColor">#FF4A3C30</Color>
    <Color x:Key="SoftPanelColor">#FF3A2E24</Color>
    <Color x:Key="IconChipColor">#FF453829</Color>
    <Color x:Key="HoverBgColor">#FF5A4A3A</Color>
    <Color x:Key="ControlBgColor">#FF382C22</Color>
    <Color x:Key="ControlBorderColor">#FF5D4D3D</Color>
    <Color x:Key="AccentColor">#FFBF8B60</Color>
    <Color x:Key="CheckMarkColor">#FF2C221A</Color>

    <SolidColorBrush x:Key="InkBrush" Color="{StaticResource InkColor}" />
    <SolidColorBrush x:Key="SubtleInkBrush" Color="{StaticResource SubtleInkColor}" />
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource CardBgColor}" />
    <SolidColorBrush x:Key="CardBorderBrush" Color="{StaticResource CardBorderColor}" />
    <SolidColorBrush x:Key="SoftPanelBrush" Color="{StaticResource SoftPanelColor}" />
    <SolidColorBrush x:Key="IconChipBrush" Color="{StaticResource IconChipColor}" />
    <SolidColorBrush x:Key="HoverBackgroundBrush" Color="{StaticResource HoverBgColor}" />
    <SolidColorBrush x:Key="ControlBackgroundBrush" Color="{StaticResource ControlBgColor}" />
    <SolidColorBrush x:Key="ControlBorderBrush" Color="{StaticResource ControlBorderColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="CheckMarkBrush" Color="{StaticResource CheckMarkColor}" />
</ResourceDictionary>
